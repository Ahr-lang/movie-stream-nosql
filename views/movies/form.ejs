<!DOCTYPE html>
<html>
<head>
  <title><%= title %></title>
</head>
<body>
  <h1><%= title %></h1>

  <nav>
    <a href="/movies">Movies</a> |
    <a href="/genres">Genres</a>
  </nav>

  <hr>

  <form method="POST" action="<%= action %>">
    <label>Movie ID</label><br>
    <input type="number" name="movieId" value="<%= movie ? movie.movieId : "" %>" required>
    <br><br>

    <label>SKU</label><br>
    <input type="text" name="sku" value="<%= movie ? movie.sku : "" %>">
    <br><br>

    <label>Title</label><br>
    <input type="text" name="title" value="<%= movie ? movie.title : "" %>" required>
    <br><br>

    <label>Year</label><br>
    <input type="number" name="year" value="<%= movie ? movie.year : "" %>">
    <br><br>

    <label>Runtime</label><br>
    <input type="text" name="runtime" value="<%= movie ? movie.runtime : "" %>">
    <br><br>

    <label>Summary</label><br>
    <textarea name="summary" rows="4" cols="60"><%= movie ? movie.summary : "" %></textarea>
    <br><br>

    <label>Image URL</label><br>
    <input type="text" name="imageUrl" value="<%= movie ? movie.imageUrl : "" %>" style="width: 400px;">
    <br><br>

    <label>List Price</label><br>
    <input type="number" step="0.01" name="listPrice" value="<%= movie ? movie.listPrice : "" %>">
    <br><br>

    <label>Main Subject</label><br>
    <input type="text" name="mainSubject" value="<%= movie ? movie.mainSubject : "" %>">
    <br><br>

    <label>Opening Date</label><br>
    <input
      type="date"
      name="openingDate"
      value="<%= movie && movie.openingDate ? movie.openingDate.toISOString().substring(0, 10) : "" %>"
    >
    <br><br>

    <label>Wiki Article</label><br>
    <input type="text" name="wikiArticle" value="<%= movie ? movie.wikiArticle : "" %>">
    <br><br>

    <label>Genres</label><br>
    <select name="genres" multiple size="5">
      <% genres.forEach((genre) => { %>
        <option
          value="<%= genre._id %>"
          <%= movie && movie.genres.map(String).includes(String(genre._id)) ? "selected" : "" %>
        >
          <%= genre.name %>
        </option>
      <% }) %>
    </select>
    <p>Hold Ctrl or Cmd to select multiple genres.</p>

    <label>Actors</label><br>
    <select name="actors" multiple size="6">
      <% actors.forEach((actor) => { %>
        <option
          value="<%= actor._id %>"
          <%= movie && movie.actors.map(String).includes(String(actor._id)) ? "selected" : "" %>
        >
          <%= actor.name %>
        </option>
      <% }) %>
    </select>
    <p>Hold Ctrl or Cmd to select multiple actors.</p>

    <label>Gross</label><br>
    <input type="text" name="gross" value="<%= movie && movie.commercial ? movie.commercial.gross : "" %>">
    <br><br>

    <label>Budget</label><br>
    <input type="text" name="budget" value="<%= movie && movie.commercial ? movie.commercial.budget : "" %>">
    <br><br>

    <label>Views</label><br>
    <input type="number" name="views" value="<%= movie && movie.commercial ? movie.commercial.views : 0 %>">
    <br><br>

    <label>Awards, separated by commas</label><br>
    <input
      type="text"
      name="awards"
      value="<%= movie && movie.awards ? movie.awards.join(', ') : "" %>"
      style="width: 400px;"
    >
    <br><br>

    <label>Nominations, separated by commas</label><br>
    <input
      type="text"
      name="nominations"
      value="<%= movie && movie.nominations ? movie.nominations.join(', ') : "" %>"
      style="width: 400px;"
    >
    <br><br>

    <button type="submit">Save</button>
  </form>

  <br>
  <a href="/movies">Back</a>
</body>
</html>
